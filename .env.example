# Google Gemini API Configuration
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Flower Server Configuration
FLOWER_SERVER_ADDRESS=[::]:8080
FLOWER_NUM_ROUNDS=10

# Optional: ChromaDB Configuration
CHROMADB_PERSIST_DIR=./chromadb_data
CHROMADB_COLLECTION=medical_xray_findings

# Optional: Ganache / Blockchain Configuration
# URL of the local Ganache node (default: http://127.0.0.1:7545)
GANACHE_URL=http://127.0.0.1:7545

# Model Governance Registry (Feature 2)
# Admin private key used to deploy the contract and register model versions.
# Leave blank to run inference UI governance check in mock/demo mode.
GOVERNANCE_ADMIN_KEY=

# Pre-deployed ModelGovernanceRegistry contract address.
# If blank, the integrator deploys a new contract using GOVERNANCE_ADMIN_KEY.
GOVERNANCE_CONTRACT_ADDRESS=

# Comma-separated list of hospital private keys (0x…) used by run_pipeline.py
# --with-governance to submit 3-of-4 approvals automatically.
# Example: GOVERNANCE_HOSPITAL_KEYS=0xHOSP1,0xHOSP2,0xHOSP3,0xHOSP4
GOVERNANCE_HOSPITAL_KEYS=
